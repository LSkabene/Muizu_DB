views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("Manor_DB")
        - '!file.inFolder("Manor_DB/Vidzeme/Test")'
    order:
      - veids
      - nosaukums_lv
      - nosaukums_ger
      - nosaukums_rus
      - nosaukums_est
      - aliases
      - guberņa
      - apriņķis
      - draudzes_novads
      - tags
      - koordinātas
      - half_manors
      - parent_manor
    sort:
      - property: veids
        direction: DESC
      - property: koordinātas
        direction: ASC
      - property: nosaukums_rus
        direction: ASC
    columnSize:
      note.veids: 90
      note.nosaukums_lv: 116
      note.aliases: 133
      note.guberņa: 104
      note.apriņķis: 95
      note.draudzes_novads: 126
      note.parent_manor: 118
    rowHeight: tall
