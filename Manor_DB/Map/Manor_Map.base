formulas:
  map_icon: list(map_icon)[0].asFile().properties.icon
views:
  - type: map
    name: Map
    filters:
      and:
        - file.inFolder("Manor_DB")
        - file.tags.contains("places")
    order: []
    center: "[56.9823009406592, 25.144262380488605]"
    coordinates: note.coordinates
    defaultZoom: 3
    markerIcon: note.map_icon
    markerColor: note.map_color
